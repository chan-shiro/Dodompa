{
  "name": "dodompa-desktop-mcp",
  "version": "1.0.0",
  "description": "MCP bridges for Dodompa — stdio proxy to the in-app HTTP MCP server (bridge), plus a legacy stdio implementation (production) and a dev/debug AX server (desktop)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dodompa-mcp-bridge": "dist/stdio-bridge.js",
    "dodompa-mcp-desktop": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:bridge": "node dist/stdio-bridge.js",
    "start:production": "node dist/production.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "playwright-core": "^1.58.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
